
# ============================================
# HTTP SMTP Relay - Variables de entorno
# ============================================

# Puerto del servidor HTTP
PORT=3001

# Secret compartido con Supabase (debe coincidir con SMTP_RELAY_SECRET)
# Generar: openssl rand -hex 32
RELAY_SECRET=CAMBIAR_POR_SECRET_FUERTE

# Servidor SMTP interno corporativo
SMTP_HOST=10.48.19.10
SMTP_PORT=25

# TLS/SSL deshabilitado (SMTP plain interno)
SMTP_SECURE=false

# Auth SMTP (dejar vacío si no se requiere)
# SMTP_USER=
# SMTP_PASS=
</file>
